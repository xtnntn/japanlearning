{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "日语阅读日报",
  "version": "0.1.0",
  "identifier": "com.xtnntn.nihongo-daily-reader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "日语阅读日报",
        "width": 1120,
        "height": 820,
        "minWidth": 960,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": { "active": true, "targets": "all", "icon": ["icons/icon.png"] }
}
