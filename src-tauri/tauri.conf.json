{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kotoba Atelier",
  "version": "0.1.0",
  "identifier": "com.xtnntn.nihongo-daily-reader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Kotoba Atelier",
        "width": 1120,
        "height": 820,
        "minWidth": 960,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "macOS": { "signingIdentity": "-" }
  }
}
